{
  "name": "@liry-k/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check-format": "prettier --check --cache .",
    "check-spell": "cspell .",
    "format": "prettier --write --cache .",
    "lint": "pnpm pre-commit",
    "lint:comment-style": "eslint ./**/*",
    "pre-commit": "pnpm check-format && pnpm check-spell && pnpm lint:comment-style && pnpm -r lint",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm pre-commit",
    "commit-msg": "pnpm commitlint --edit"
  },
  "dependencies": {
    "cspell": "^9.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@liry-k/tsconfig": "workspace:*",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "pkg-types": "^2.3.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^2.5.22",
    "simple-git-hooks": "^2.13.1",
    "typescript-eslint": "^8.58.1"
  }
}
