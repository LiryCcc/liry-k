{
  "name": "liry-k",
  "type": "module",
  "scripts": {
    "check-format": "prettier --check --cache .",
    "check-spell": "cspell .",
    "format": "prettier --write --cache .",
    "pre-commit": "pnpm check-format && pnpm check-spell && pnpm -r lint",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm pre-commit",
    "commit-msg": "pnpm commitlint --edit"
  },
  "dependencies": {
    "cspell": "^9.7.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^2.5.22",
    "simple-git-hooks": "^2.13.1"
  }
}
